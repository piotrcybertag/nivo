APP_NAME=Nivo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Przy php artisan serve ustaw port, żeby generowane URL-e (kanoniczne, OG) zgadzały się z paskiem przeglądarki:
APP_URL=http://127.0.0.1:8000

# Link do Stripe Payment Link (plan Full) — bez ?client_reference_id (dopina aplikacja)
STRIPE_PAYMENT_LINK=https://buy.stripe.com/dRm5kDcDlcuFciZ1VaafS02
# Sekret API (sk_test_... / sk_live_...) — weryfikacja session_id na stronie powrotu
STRIPE_SECRET_KEY=
# W Stripe Dashboard: Payment Link → After payment → np.:
# https://twoja-domena.pl/platnosc/full/dziekujemy?session_id={CHECKOUT_SESSION_ID}

# Google Analytics 4 (only runs in production when set; reuse in other cyberrum apps)
# GA_MEASUREMENT_ID=G-CZL55K8WKE

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Log audytowy admina (landing / rejestracja / logowanie / Stripe Full) → storage/logs/admin-YYYY-MM-DD.log
ADMIN_AUDIT_LOG_ENABLED=true
# Ile dni trzymać stare pliki admin-*.log (daily channel)
ADMIN_LOG_DAYS=90

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
# Na local często lepiej: SESSION_DRIVER=file (szybsze niż database)
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# Na local często lepiej: CACHE_STORE=file (szybsze niż database)
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# E-mail Scout Solutions (stopka landing — link mailto)
# SCOUT_CONTACT_EMAIL=info@scoutsolutions.eu

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
